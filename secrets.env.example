# 复制为 logs/secrets.env 或 secrets.env（勿提交真实密钥）
PUSHPLUS_TOKEN=
# ClawBot 收消息(getMsg) 必填：PushPlus 个人中心 → 开发设置 → SecretKey
PUSHPLUS_SECRET_KEY=
# 可选：本地 Codex CLI 不可用时，使用 OpenAI Responses API
# OPENAI_API_KEY=
# 可选：指定 Codex 模型；不填则本地 Codex CLI 使用自身默认模型
# TP_CODEX_MODEL=gpt-5.1-codex
TP_CODEX_REASONING_EFFORT=low
# 默认推送：clawbot（微信 ClawBot）；需定期在 ClawBot 里发消息保持激活
TP_PUSHPLUS_CHANNEL=clawbot
# 仅 ClawBot 查询/AI 回复（一般与上面相同）
TP_CLAWBOT_REPLY_CHANNEL=clawbot
# 可选：ClawBot 推送失败时再发公众号 TP_CLAWBOT_REPLY_FALLBACK=wechat
# TP_NODE_PATH=C:\Program Files\nodejs\node.exe
# 新闻标题英译中（MyMemory + Google 备用）
TP_NEWS_TRANSLATE_ENABLED=1
TP_NEWS_TRANSLATE_TIMEOUT=8
# PushPlus / ClawBot 网络（连接慢时可加大）
# TP_PUSHPLUS_CONNECT_TIMEOUT=25
# TP_CLAWBOT_LONG_POLL_READ_TIMEOUT=60
# TP_PUSHPLUS_READ_TIMEOUT=30
# TP_PUSHPLUS_HTTP_RETRIES=3
# 仅当 HTTPS 均失败且确需时再开 HTTP 回退（默认关闭，避免 DNS 失败刷 port=80 日志）
# TP_PUSHPLUS_ALLOW_HTTP=0
# 自定义 API 根地址（可选）: TP_PUSHPLUS_API_BASE=https://www.pushplus.plus
